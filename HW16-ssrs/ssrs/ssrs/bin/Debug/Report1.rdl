  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource11</DataSourceName>
        <CommandText>SELECT TOP (1000) [PolicyID]
      ,[TypeOfPolicy]
      ,[Status]
      ,[Agent]
      ,[Client]
      ,[PolicyData]
      ,[Premium]
      ,[Sum]
  FROM [Insuranse].[dbo].[Policy]</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
